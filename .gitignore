# Python cache files — auto-generated, don't need to track
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environment — contains installed packages, too large to commit
venv/
env/
.env/
.venv/

# Trained model files — can be regenerated by running train.py
*.pkl
*.joblib
models/

# pytest cache
.pytest_cache/
.cache/

# Pylint cache
.pylint.d/

# macOS system files — not relevant to the project
.DS_Store
.AppleDouble
.LSOverride

# IDE settings — personal preference, not part of the project
.vscode/
.idea/
*.swp

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Coverage reports
htmlcov/
.coverage
coverage.xml
